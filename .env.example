# CreditOps — variáveis de ambiente
# Copie para .env (nunca commitar .env) ou exporte no serviço/systemd.

# Chave usada para assinar cookies de sessão e tokens CSRF.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
CREDITOPS_SECRET_KEY=troque-esta-chave-em-producao

# Caminho do banco SQLite (padrão: data/creditops.db)
CREDITOPS_DB_PATH=data/creditops.db

# Diretório de dados de runtime (anexos, exports)
CREDITOPS_DATA_DIR=data

# Cookie de sessão só via HTTPS (true em produção; false para dev local em http)
CREDITOPS_COOKIE_SECURE=true
