# CreditOps — variáveis de ambiente
# Copie para .env (nunca commitar .env) ou exporte no serviço/systemd.

# Chave usada para assinar cookies de sessão e tokens CSRF.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
CREDITOPS_SECRET_KEY=troque-esta-chave-em-producao

# Caminho do banco SQLite (padrão: data/creditops.db)
CREDITOPS_DB_PATH=data/creditops.db

# Diretório de dados de runtime (anexos, exports)
CREDITOPS_DATA_DIR=data

# Cookie de sessão só via HTTPS (true em produção; false para dev local em http)
CREDITOPS_COOKIE_SECURE=true

# v1 — senha do SMTP corporativo (usada apenas se notify_email = true no
# settings.toml; os demais parâmetros SMTP ficam no settings.toml)
# CREDITOPS_SMTP_PASSWORD=

# v2 — senha da conta de serviço LDAP (modo busca+bind; demais parâmetros
# LDAP ficam no settings.toml)
# CREDITOPS_LDAP_BIND_PASSWORD=

# v2 — segredo da assinatura HMAC dos webhooks de publicação
# CREDITOPS_WEBHOOK_SECRET=

# v2 — credencial do provedor de IA (NUNCA no settings.toml nem no banco);
# alternativa: CREDITOPS_AI_KEY_FILE apontando para arquivo com permissão restrita
# CREDITOPS_AI_API_KEY=
# CREDITOPS_AI_KEY_FILE=

